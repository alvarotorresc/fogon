---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fogon — Tu cocina, organizada</title>
    <meta name="description" content="Organiza la cocina con tu pareja. Lista de la compra en tiempo real, despensa, recetario y planificador semanal." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Geist', -apple-system, sans-serif;
        background: #0A0A0A;
        color: #EDEDED;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }
      .logo {
        width: 80px;
        height: 80px;
        margin-bottom: 1.5rem;
      }
      h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        text-align: center;
      }
      .tagline {
        color: #A3A3A3;
        font-size: 1.25rem;
        margin-bottom: 2rem;
        text-align: center;
        max-width: 480px;
      }
      .cta {
        background: #3291FF;
        color: white;
        padding: 0.875rem 2rem;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .cta:hover { opacity: 0.85; }
      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        max-width: 640px;
        margin-top: 3rem;
      }
      .feature {
        background: #111111;
        border: 1px solid #2E2E2E;
        border-radius: 12px;
        padding: 1.25rem;
        text-align: center;
      }
      .feature-icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
      .feature-title { font-weight: 600; margin-bottom: 0.25rem; }
      .feature-desc { color: #A3A3A3; font-size: 0.875rem; }
      footer {
        margin-top: 4rem;
        color: #525252;
        font-size: 0.875rem;
      }
      footer a { color: #A3A3A3; text-decoration: none; }
      footer a:hover { color: #EDEDED; }
    </style>
  </head>
  <body>
    <svg class="logo" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M16 29C11 29 6 24 7 17C8 10 12 4 16 3C20 4 24 10 25 17C26 24 21 29 16 29Z" fill="#EA580C" />
      <path d="M16 24C13.5 24 12 21.5 12.5 18.5C13 15.5 14.5 13 16 13C17.5 13 19 15.5 19.5 18.5C20 21.5 18.5 24 16 24Z" fill="white" fill-opacity="0.22" />
    </svg>
    <h1>Fogon</h1>
    <p class="tagline">Organiza la cocina con tu pareja. Lista de la compra en tiempo real, despensa, recetario y planificador semanal.</p>
    <a href="#" class="cta">Descarga la app</a>

    <div class="features">
      <div class="feature">
        <div class="feature-icon">🛒</div>
        <div class="feature-title">Lista de la compra</div>
        <div class="feature-desc">Sincronizada en tiempo real</div>
      </div>
      <div class="feature">
        <div class="feature-icon">🏠</div>
        <div class="feature-title">Despensa</div>
        <div class="feature-desc">Control de stock visual</div>
      </div>
      <div class="feature">
        <div class="feature-icon">📖</div>
        <div class="feature-title">Recetario</div>
        <div class="feature-desc">Tus recetas + coleccion Fogon</div>
      </div>
      <div class="feature">
        <div class="feature-icon">📅</div>
        <div class="feature-title">Menu semanal</div>
        <div class="feature-desc">Planifica comida y cena</div>
      </div>
    </div>

    <footer>
      Made with 🔥 by <a href="https://alvarotc.com">Alvaro Torres</a>
    </footer>
  </body>
</html>
